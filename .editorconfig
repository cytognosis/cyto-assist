root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 119

[*.py]
indent_size = 4
max_line_length = 119

[{*.{yml,yaml,toml},.cruft.json}]
indent_size = 2
max_line_length = 119

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[{*.{js,ts,jsx,tsx}}]
indent_size = 2
max_line_length = 100

[*.{html,css,scss}]
indent_size = 2

[Makefile]
indent_style = tab

[{.cursorrules,.windsurfrules}]
trim_trailing_whitespace = false
max_line_length = off
