extends: default

rules:
  line-length:
    max: 119
  comments:
    min-spaces-from-content: 1
  document-start: disable
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']

ignore: |
  scratch/
  repos/
  .git/
  .mypy_cache/
  .pytest_cache/
  .ruff_cache/
  .nox/
  .venv/
  venv/
  build/
  dist/
experiments/**/logs/
  experiments/**/results/
  experiments/**/checkpoints/
  experiments/**/data/
